{
  "name": "cadernos-vivos",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=dot",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:ci": "node tools/run-e2e-ci.mjs",
    "test:ui": "playwright test --config=playwright.config.ts tests/e2e/visual.spec.ts",
    "test:ui:ci": "node tools/run-ui-ci.mjs",
    "demo:seed": "node tools/seed-demo.mjs",
    "demo:import": "node tools/import-sources.mjs",
    "secrets:check": "node tools/secrets-check.mjs",
    "verify": "npm run lint && npm run typecheck && npm run build",
    "supabase:check": "node tools/check-supabase.mjs",
    "db:login": "node tools/supabase-cli.mjs login",
    "db:link": "node tools/supabase-cli.mjs link",
    "db:push": "node tools/supabase-cli.mjs push",
    "db:deploy": "node tools/supabase-cli.mjs deploy",
    "db:status": "node tools/supabase-cli.mjs status"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@types/pdf-parse": "^1.1.5",
    "next": "^15.0.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
